# Required in Vercel deployments for the earn/referral forms.
RESEND_API_KEY=

# Optional comma-separated recipients. Defaults to hello@plistic.media when unset.
EARN_NOTIFY_EMAIL=hello@plistic.media

# Optional, but should be a Resend-verified sender domain before launch.
EARN_FROM_EMAIL="Plistic <hello@plistic.media>"
