# Required in Vercel deployments for the earn/referral forms.
RESEND_API_KEY=

# Optional comma-separated recipients. Defaults to hello@plisticmedia.com when unset.
EARN_NOTIFY_EMAIL=hello@plisticmedia.com

# Optional, but should be a Resend-verified sender domain before launch.
EARN_FROM_EMAIL="Plistic <hello@updates.plisticmedia.com>"
PRICING_FROM_EMAIL="Plistic <hello@updates.plisticmedia.com>"
