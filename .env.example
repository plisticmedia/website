# =============================================================================
# Plistic Media — environment variables
# Copy to .env.local for local dev. In production, set these in Vercel.
# NEVER commit real keys. NEVER paste secret keys into chat.
# =============================================================================

# --- Email (Resend) — already used by /api/earn ---------------------------
# Required for the lead-gen forms to send notifications + auto-replies.
RESEND_API_KEY=
# Optional comma-separated internal recipients. Defaults to hello@plistic.media.
EARN_NOTIFY_EMAIL=hello@plistic.media
# Required in Production. Must use a domain verified in Resend.
EARN_FROM_EMAIL="Plistic <hello@plistic.media>"

# --- Supabase -------------------------------------------------------------
# Project URL + anon key are PUBLIC (safe in the browser).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key is SECRET. Server-side only (webhooks, form ingestion, admin).
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ----------------------------------------------------------------
# Secret + webhook signing secret are SECRET. Publishable key is public.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Recurring price ID for the featured-listing subscription (Stripe Billing).
STRIPE_FEATURED_PRICE_ID=

# --- Cal.com (booking) -----------------------------------------------------
# Webhook signing secret used to verify incoming booking events.
CALCOM_WEBHOOK_SECRET=

# --- App -------------------------------------------------------------------
# Public base URL of the site (used for Stripe redirect URLs, emails, etc.).
NEXT_PUBLIC_SITE_URL=https://www.plisticmedia.com
