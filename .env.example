# =============================================================================
# Plistic Media — environment variables
# Copy to .env.local for local dev. In production, set these in Vercel.
# NEVER commit real keys. NEVER paste secret keys into chat.
# =============================================================================

# --- Email (Resend) — used by /api/earn, /api/pricing-lead, /api/enquiries ---
# Required for the lead-gen + enquiry forms to send notifications + auto-replies.
RESEND_API_KEY=
# Optional comma-separated internal recipients. Defaults to hello@plisticmedia.com.
EARN_NOTIFY_EMAIL=hello@plisticmedia.com
# Sender addresses — must be on a Resend-verified domain.
EARN_FROM_EMAIL="Plistic <hello@updates.plisticmedia.com>"
PRICING_FROM_EMAIL="Plistic <hello@updates.plisticmedia.com>"

# --- Supabase -------------------------------------------------------------
# Project URL + anon key are PUBLIC (safe in the browser).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key is SECRET. Server-side only (webhooks, form ingestion, admin).
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (per-account featured subscription) ---------------------------
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# The two recurring Price IDs (price_...) for the featured membership.
STRIPE_FEATURED_PRICE_YEARLY=
STRIPE_FEATURED_PRICE_MONTHLY=

# --- Cal.com (booking webhook) --------------------------------------------
CALCOM_WEBHOOK_SECRET=

# --- Google ratings (directory listings) ----------------------------------
# Google Cloud "Places API (New)" key. When set, the directory fetches each
# business's Google rating + review count (admin button + nightly cron).
# Leave blank to keep the feature dormant.
GOOGLE_PLACES_API_KEY=
# Secret guarding the scheduled cron runs (/api/cron/*). Set to any long random
# string; Vercel Cron sends it automatically once configured.
CRON_SECRET=

# --- Google Form auto-import (optional) -----------------------------------
# The responses sheet's "File → Share → Publish to web → CSV" link. When set,
# a daily cron imports new form responses as pending listings automatically.
GOOGLE_SHEET_CSV_URL=

# --- App -------------------------------------------------------------------
# Public base URL of the site (used for Stripe redirect URLs, emails, etc.).
NEXT_PUBLIC_SITE_URL=https://www.plisticmedia.com

# LAUNCH SWITCH. While unset the whole site stays behind the coming-soon
# password. Set to "true" to make the site public (launch day). Reversible.
SITE_LIVE=

# Peer confidence (Layer 2): set to "true" to switch on the PUBLIC peer-confidence
# aggregate on profiles. Leave unset/false until legal sign-off. Everything else
# (worked-with, private feedback) works regardless of this flag.
PEER_CONFIDENCE_PUBLIC=
