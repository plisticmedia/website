{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm build",
  "crons": [
    {
      "path": "/api/cron/ratings",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/import-sheet",
      "schedule": "0 5 * * *"
    }
  ]
}
